{
  "manifest_version": 3,
  "name": "TokenForge AI - LLM Optimizer",
  "version": "1.0.0",
  "description": "Optimize and compress prompts/JSON for LLM APIs.",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": ["activeTab", "clipboardWrite", "storage"],
  "host_permissions": ["http://localhost:5000/*"]
}
